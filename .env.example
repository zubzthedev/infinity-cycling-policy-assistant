# Copy this file to .env and fill in real values for local development.
# In Cloud Run, these are set via --set-env-vars / --set-secrets instead of a .env file.

ENVIRONMENT=local

# --- Gemini ---
GEMINI_API_KEY=changeme
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=30

# --- Firebase Auth ---
# These are Firebase's public web config values (safe to expose to the
# browser) - copy them from Firebase console > Project settings > Your apps.
FIREBASE_PROJECT_ID=changeme
FIREBASE_API_KEY=changeme
FIREBASE_AUTH_DOMAIN=changeme.firebaseapp.com
FIREBASE_APP_ID=changeme
# Path to a service account JSON file (local dev only; Cloud Run uses the
# runtime service identity or a mounted Secret Manager volume instead).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Access control (comma-separated email addresses, case-insensitive) ---
AUTHORISED_USERS=
ADMIN_USERS=

# --- Policies / prompts ---
# POLICY_SOURCE=local reads POLICY_DIR on disk (used for local dev, tests,
# and the checked-in seed content). POLICY_SOURCE=drive fetches every .md
# file from a shared Google Drive folder instead, using the same service
# account as GOOGLE_APPLICATION_CREDENTIALS above (share the Drive folder
# with that account's client_email, "Viewer" access is enough) - this is
# what EXCO actually manages day to day, since it survives Cloud Run
# redeploys and needs no custom upload UI.
POLICY_SOURCE=local
POLICY_DIR=policies
DRIVE_FOLDER_ID=
PROMPT_DIR=prompts

# --- Logging ---
LOG_QUESTIONS=true
LOG_RESPONSES=false

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=10
