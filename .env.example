# Copy this file to .env and fill in real values for local development.
# In Cloud Run, these are set via --set-env-vars / --set-secrets instead of a .env file.

ENVIRONMENT=local

# --- Gemini ---
GEMINI_API_KEY=changeme
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=changeme
# Path to a service account JSON file (local dev only; Cloud Run uses the
# runtime service identity or a mounted Secret Manager volume instead).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Access control (comma-separated email addresses, case-insensitive) ---
AUTHORISED_USERS=
ADMIN_USERS=

# --- Policies / prompts ---
POLICY_DIR=policies
PROMPT_DIR=prompts

# --- Logging ---
LOG_QUESTIONS=true
LOG_RESPONSES=false

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=10
